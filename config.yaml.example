# reel-processor configuration
# Copy this file to config.yaml and fill in your values.

# Path to the project root containing numbered subfolders (1/, 2/, 3/, ...)
icloud_root: "/Users/paolone/Library/Mobile Documents/com~apple~CloudDocs/Progetto RP"

# Path where run_log.json is saved (final videos go inside numbered folders)
output_dir: "/Users/paolone/Library/Mobile Documents/com~apple~CloudDocs/Progetto RP/_output"

# Global background music file (loops automatically to match video length)
background_music: ~/Music/background-track.mp3

# Volume offset for background music relative to voiceover (in dB)
music_volume_db: -25

# Gain applied to the voiceover track (in dB)
voiceover_gain_db: 0

# Mirage caption template ID — run `python main.py list-templates` to find yours
caption_template_id: ctpl_YOUR_TEMPLATE_ID_HERE

# Mirage API key from https://platform.mirage.app
mirage_api_key: your_api_key_here

# Seconds between status polls when waiting for Mirage processing
poll_interval_seconds: 5

# Maximum number of poll attempts before marking a job as failed
max_poll_attempts: 20

# Extra seconds added to voiceover duration when trimming video
video_trim_extra_seconds: 1

# Maximum output file size in MB for Mirage upload (warns if exceeded)
max_file_size_mb: 50

# Output resolution for upscale step — 4K vertical 9:16 (2160x3840)
output_width: 2160
output_height: 3840

# Upscale Mirage output to output_width x output_height and convert to HLG.
# true  → re-encode with libx265, optional SDR brightness correction,
#         zscale SDR→HLG, output shows "4K HLG" in players
# false → remux only (stream-copy video), inject HLG container tags, no re-encode
#         Use false if you want zero extra quality loss and don't need 4K metadata.
upscale_output: true

# Optional post-Mirage color correction applied during FINALIZE before SDR→HLG.
# Keep both at 1.0 to disable correction.
# Example values from screenshot analysis:
#   gamma: 0.53
#   saturation: 1.05
# This is a cosmetic correction for Mirage SDR output, not true HDR recovery.
color_correction_gamma: 1.0
color_correction_saturation: 1.0

# CRF for the final upscale+HLG encode (only used when upscale_output: true)
# Lower = higher quality, larger file. 18 is a good starting point for 4K HEVC.
video_crf: 18

# CRF for Mirage upload intermediate (SDR, no HLG). Higher values are fine here
# since Mirage will re-encode anyway. 24 balances upload size vs. caption quality.
mirage_upload_crf: 24

# Mirage API base URL (change only if using a different environment)
# mirage_base_url: https://api.mirage.app/v1
